# Powerlevel10k Configuration - Rainbow Style
# Generated for use with Oh My Zsh + Chezmoi dotfiles.
# Managed by Chezmoi. Do not edit directly.
# Source: chezmoi/dot_p10k.zsh.tmpl
# ============================================================================
#
# Style: Rainbow (colored background segments with powerline separators)
# Prompt: 2-line, full frame (╭─ / ╰─ on left, ─╮ / ─╯ on right)
# Separators: Angled (powerline arrows: \uE0B0 / \uE0B2), sharp heads, flat tails
# Spacing: Sparse (empty line before each prompt)
# Transient: always
# Instant prompt: verbose
# Icons: Nerdfont v3
#
# P10k uses terminal color indices (0-15). The Kitty theme files define
# what each color index actually looks like (each Catppuccin variant maps
# colors differently). So this file stays the SAME regardless of theme —
# the terminal emulator's color scheme does the work.
#
# To re-generate from scratch: p10k configure
# To customize: edit this file directly.
#
# Based on the standard p10k-rainbow configuration output.
# See: https://github.com/romkatv/powerlevel10k

# Temporarily change options.
'builtin' 'local' '-a' 'p10k_config_opts'
[[ ! -o 'aliases'         ]] || p10k_config_opts+=('aliases')
[[ ! -o 'sh_glob'         ]] || p10k_config_opts+=('sh_glob')
[[ ! -o 'no_brace_expand' ]] || p10k_config_opts+=('no_brace_expand')
'builtin' 'setopt' 'no_aliases' 'no_sh_glob' 'brace_expand'

() {
  emulate -L zsh -o extended_glob

  # Unset all configuration options. This allows you to apply configuration
  # changes without restarting zsh. Edit this file and type `source ~/.p10k.zsh`.
  unset -m '(POWERLEVEL9K_*|DEFAULT_USER)~POWERLEVEL9K_GITSTATUS_DIR'

  # Zsh >= 5.1 is required.
  [[ $ZSH_VERSION == (5.<1->*|<6->.*) ]] || return

  ##################################[ SEGMENTS ]##################################
  #                                                                              #
  # Segments are the building blocks of the prompt. Each segment shows a piece   #
  # of information. Segments can be added, removed, or reordered freely.         #
  #                                                                              #
  # To add a segment to LEFT_PROMPT_ELEMENTS or RIGHT_PROMPT_ELEMENTS, find      #
  # its configuration section below, uncomment/enable it, and add the segment    #
  # name to the appropriate array.                                               #
  #                                                                              #
  # To remove a segment, simply remove it from the array. Its configuration      #
  # section can remain — it won't cause any harm or performance impact.          #
  #                                                                              #
  ################################################################################

  # The list of segments shown on the left. Fill it with the most important segments.
  typeset -g POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(
    # =========================[ Line #1 ]=========================
    os_icon                 # OS identifier (Apple/Linux/etc.)
    dir                     # current directory
    vcs                     # git status
    # =========================[ Line #2 ]=========================
    newline                 # \n
    prompt_char             # prompt symbol
  )

  # The list of segments shown on the right. Fill it with less important segments.
  # Right prompt on the last prompt line (where you are typing your commands) gets
  # automatically hidden when the input line reaches it. Right prompt above the
  # last prompt line gets hidden if it would overlap with left prompt.
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(
    # =========================[ Line #1 ]=========================
    status                  # exit code of the last command
    command_execution_time  # duration of the last command
    background_jobs         # presence of background jobs
    direnv                  # direnv status (https://direnv.net/)
    asdf                    # asdf version manager (https://github.com/asdf-vm/asdf)
    virtualenv              # python virtual environment (https://docs.python.org/3/library/venv.html)
    anaconda                # conda environment (https://conda.io/)
    pyenv                   # python environment (https://github.com/pyenv/pyenv)
    goenv                   # go environment (https://github.com/syndbg/goenv)
    nodenv                  # node.js version from nodenv (https://github.com/nodenv/nodenv)
    nvm                     # node.js version from nvm (https://github.com/nvm-sh/nvm)
    nodeenv                 # node.js environment (https://github.com/ekalinin/nodeenv)
    # node_version          # node.js version
    # go_version            # go version (https://golang.org)
    # rust_version          # rustc version (https://www.rust-lang.org)
    # dotnet_version        # .NET version (https://dotnet.microsoft.com)
    # php_version           # php version (https://www.php.net/)
    # laravel_version       # laravel php framework version (https://laravel.com/)
    # java_version          # java version (https://www.java.com/)
    # package               # name@version from package.json (https://docs.npmjs.com/files/package.json)
    # rbenv                 # ruby version from rbenv (https://github.com/rbenv/rbenv)
    # rvm                   # ruby version from rvm (https://rvm.io)
    # fvm                   # flutter version management (https://github.com/aspect-build/rules_dart)
    # luaenv                # lua version from luaenv (https://github.com/cehoffman/luaenv)
    # jenv                  # java version from jenv (https://github.com/jenv/jenv)
    # plenv                 # perl version from plenv (https://github.com/tokuhirom/plenv)
    # perlbrew              # perl version from perlbrew (https://perlbrew.pl/)
    # phpenv                # php version from phpenv (https://github.com/phpenv/phpenv)
    # scalaenv              # scala version from scalaenv (https://github.com/scalaenv/scalaenv)
    # haskell_stack         # haskell version from stack (https://haskellstack.org/)
    # kubecontext           # current kubernetes context (https://kubernetes.io/)
    # terraform             # terraform workspace (https://www.terraform.io)
    # terraform_version     # terraform version (https://www.terraform.io)
    # aws                   # aws profile (https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-profiles.html)
    # aws_eb_env            # aws elastic beanstalk environment (https://aws.amazon.com/elasticbeanstalk/)
    # azure                 # azure account name (https://docs.microsoft.com/en-us/cli/azure)
    # gcloud                # google cloud cli account and project (https://cloud.google.com/)
    # google_app_cred       # google application credentials (https://cloud.google.com/docs/authentication/production)
    # toolbox               # toolbox name (https://github.com/containers/toolbox)
    context                 # user@hostname
    # nordvpn               # nordvpn connection status, currentserver, country, city (https://nordvpn.com/)
    # ranger                # ranger shell (https://github.com/ranger/ranger)
    # yazi                  # yazi shell (https://github.com/sxyazi/yazi)
    # nnn                   # nnn shell (https://github.com/jarun/nnn)
    # lf                    # lf shell (https://github.com/gokcehan/lf)
    # xplr                  # xplr shell (https://github.com/sayanarijit/xplr)
    # vim_shell             # vim shell indicator (:sh)
    # midnight_commander    # midnight commander shell (https://midnight-commander.org/)
    # nix_shell             # nix shell (https://nixos.org/nixos/nix-pills/developing-with-nix-shell.html)
    # chezmoi_shell         # chezmoi shell (https://www.chezmoi.io/)
    chezmoi_shell           # chezmoi shell indicator
    # vi_mode               # vi mode (you don't need this if you've enabled prompt_char)
    # vpn_ip                # virtual private network indicator
    # load                  # CPU load
    # disk_usage            # disk usage
    # ram                   # free RAM
    # swap                  # used swap
    # todo                  # todo items (https://github.com/todotxt/todo.txt-cli)
    # timewarrior           # timewarrior tracking status (https://timewarrior.net/)
    # taskwarrior           # taskwarrior task count (https://taskwarrior.org/)
    # per_directory_history # Oh My Zsh per-directory-history local/global indicator
    # cpu_arch              # CPU architecture
    # time                  # current time
    # ip                    # ip address and bandwidth usage for a specified network interface
    # public_ip             # public IP address
    # proxy                 # system-wide http/https/ftp proxy
    # battery               # internal battery
    # wifi                  # wifi speed
    # =========================[ Line #2 ]=========================
    newline                 # \n
  )

  ##################################[ MODE ]######################################

  # Defines the overall look and feel of the prompt.
  typeset -g POWERLEVEL9K_MODE='nerdfont-v3'

  # When set to `moderate`, some icons will have an extra space after them. This
  # is meant to avoid temporary alignment issues caused by the wider icons.
  # When set to `none`, wider icons may cause prompt jumping on the first refresh.
  typeset -g POWERLEVEL9K_ICON_PADDING=moderate

  # When set to true, icons may use wider symbols. This is usually fine on modern
  # terminals but may cause prompt to jump on first refresh on some terminals.
  typeset -g POWERLEVEL9K_ICON_BEFORE_CONTENT=

  # Add an empty line before each prompt.
  typeset -g POWERLEVEL9K_PROMPT_ADD_NEWLINE=true

  #############################[ PROMPT FRAME ]##################################

  # Connect left prompt lines with these symbols.
  #   ╭─ <left prompt line 1> ─────────────────── <right prompt line 1> ─╮
  #   ├─ <left prompt line 2> ─────────────────── <right prompt line 2> ─┤
  #   ╰─ <left prompt line 3>                                            ─╯
  typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_PREFIX='%240F╭─'
  typeset -g POWERLEVEL9K_MULTILINE_NEWLINE_PROMPT_PREFIX='%240F├─'
  typeset -g POWERLEVEL9K_MULTILINE_LAST_PROMPT_PREFIX='%240F╰─'

  # Connect right prompt lines with these symbols.
  typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_SUFFIX='%240F─╮'
  typeset -g POWERLEVEL9K_MULTILINE_NEWLINE_PROMPT_SUFFIX='%240F─┤'
  typeset -g POWERLEVEL9K_MULTILINE_LAST_PROMPT_SUFFIX='%240F─╯'

  # Filler between left and right prompt on the first prompt line. You can set it
  # to '─' for a pointed line, to '·' for a dotted line, to '─' for a dashed line,
  # to ' ' for no line, or to any other character.
  typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_GAP_CHAR='─'
  typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_GAP_BACKGROUND=
  typeset -g POWERLEVEL9K_MULTILINE_NEWLINE_PROMPT_GAP_BACKGROUND=
  if [[ $POWERLEVEL9K_MULTILINE_FIRST_PROMPT_GAP_CHAR != ' ' ]]; then
    # The color of the filler. Match the frame color (240).
    typeset -g POWERLEVEL9K_MULTILINE_FIRST_PROMPT_GAP_FOREGROUND=240
    # Start filler from the edge of the screen if there are no left segments on
    # the first line.
    typeset -g POWERLEVEL9K_EMPTY_LINE_LEFT_PROMPT_FIRST_SEGMENT_END_SYMBOL='%{%}'
    # End filler on the edge of the screen if there are no right segments on the
    # first line.
    typeset -g POWERLEVEL9K_EMPTY_LINE_RIGHT_PROMPT_FIRST_SEGMENT_START_SYMBOL='%{%}'
  fi

  ############################[ SEPARATORS ]######################################

  # Separator between same-color segments on the left.
  typeset -g POWERLEVEL9K_LEFT_SUBSEGMENT_SEPARATOR='\uE0B1'
  # Separator between same-color segments on the right.
  typeset -g POWERLEVEL9K_RIGHT_SUBSEGMENT_SEPARATOR='\uE0B3'
  # Separator between different-color segments on the left.
  typeset -g POWERLEVEL9K_LEFT_SEGMENT_SEPARATOR='\uE0B0'
  # Separator between different-color segments on the right.
  typeset -g POWERLEVEL9K_RIGHT_SEGMENT_SEPARATOR='\uE0B2'
  # The right end of left prompt.
  typeset -g POWERLEVEL9K_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL='\uE0B0'
  # The left end of right prompt.
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_FIRST_SEGMENT_START_SYMBOL='\uE0B2'
  # The left end of left prompt.
  typeset -g POWERLEVEL9K_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL=''
  # The right end of right prompt.
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_LAST_SEGMENT_END_SYMBOL=''

  # Ruler between commands. Disabled for the rainbow style — the frame
  # provides enough visual separation.
  typeset -g POWERLEVEL9K_SHOW_RULER=false
  typeset -g POWERLEVEL9K_RULER_CHAR='─'
  typeset -g POWERLEVEL9K_RULER_FOREGROUND=240

  ##################################[ os_icon: os identifier ]##################################

  # OS identifier color.
  typeset -g POWERLEVEL9K_OS_ICON_FOREGROUND=255
  typeset -g POWERLEVEL9K_OS_ICON_BACKGROUND=0
  # Custom icon.
  # typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION='⭐'

  ################################[ prompt_char: prompt symbol ]################################

  # Transparent background.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_BACKGROUND=
  # Green prompt symbol if the last command succeeded.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_{VIINS,VICMD,VIVIS,VIOWR}_FOREGROUND=2
  # Red prompt symbol if the last command failed.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_{VIINS,VICMD,VIVIS,VIOWR}_FOREGROUND=1
  # Default prompt symbol.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VIINS_CONTENT_EXPANSION='❯'
  # Prompt symbol in command vi mode.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VICMD_CONTENT_EXPANSION='❮'
  # Prompt symbol in visual vi mode.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VIVIS_CONTENT_EXPANSION='V'
  # Prompt symbol in overwrite vi mode.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VIOWR_CONTENT_EXPANSION='▶'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OVERWRITE_STATE=true
  # No line terminator if prompt_char is the last segment.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL=''
  # No line introducer if prompt_char is the first segment.
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL=

  ##################################[ dir: current directory ]##################################

  # Current directory background color.
  typeset -g POWERLEVEL9K_DIR_BACKGROUND=4
  # Default current directory foreground color.
  typeset -g POWERLEVEL9K_DIR_FOREGROUND=255
  # If directory is too long, shorten some of its segments to the shortest possible unique
  # prefix. The shortened directory can be tab-completed to the original.
  typeset -g POWERLEVEL9K_SHORTEN_STRATEGY=truncate_to_unique
  # Replace removed segment suffixes with this symbol.
  typeset -g POWERLEVEL9K_SHORTEN_DELIMITER=
  # Color of the shortened directory segments.
  typeset -g POWERLEVEL9K_DIR_SHORTENED_FOREGROUND=253
  # Color of the anchor directory segments. Anchor segments are never shortened. The first
  # segment is always an anchor.
  typeset -g POWERLEVEL9K_DIR_ANCHOR_FOREGROUND=255
  # Display anchor directory segments in bold.
  typeset -g POWERLEVEL9K_DIR_ANCHOR_BOLD=true
  # Don't shorten this many last directory segments. They are anchors.
  typeset -g POWERLEVEL9K_SHORTEN_DIR_LENGTH=1
  # Shorten directory if it's longer than this even if there is space for it. The value
  # can be either absolute (e.g., '80') or a percentage of terminal width (e.g, '50%').
  # If empty, directory will be shortened only when the prompt doesn't fit or when
  # you manually set POWERLEVEL9K_SHORTEN_DIR_LENGTH.
  typeset -g POWERLEVEL9K_DIR_MAX_LENGTH=80
  # When `dir` segment is on the last prompt line, try to shorten it enough to leave at
  # least this many columns for typing commands.
  typeset -g POWERLEVEL9K_DIR_MIN_COMMAND_COLUMNS=40
  # When `dir` segment is on the last prompt line, try to shorten it enough to leave at
  # least POWERLEVEL9K_DIR_MIN_COMMAND_COLUMNS columns for typing commands on macOS.
  typeset -g POWERLEVEL9K_DIR_MIN_COMMAND_COLUMNS_PCT=50
  # Enable special styling for non-writable and non-existent directories. See POWERLEVEL9K_LOCK_ICON
  # and POWERLEVEL9K_DIR_CLASSES below.
  typeset -g POWERLEVEL9K_DIR_SHOW_WRITABLE=v3

  # These directory classes configure styles for different types of directories.
  # The first matching class wins.
  #
  # Classes are:
  #   NOT_WRITABLE   -- the current directory is not writable by the current user
  #   NON_EXISTENT   -- the current directory does not exist
  #   HOME           -- the current directory is $HOME
  #   HOME_SUBFOLDER -- the current directory is a subfolder of $HOME
  #   ETC            -- the current directory is /etc or its subdirectory
  #   DEFAULT        -- everything else
  #
  # If directory class is not defined, the DEFAULT styling is used.

  # NOT_WRITABLE directory class — red background, lock icon.
  typeset -g POWERLEVEL9K_DIR_NOT_WRITABLE_BACKGROUND=1
  typeset -g POWERLEVEL9K_DIR_NOT_WRITABLE_FOREGROUND=255
  # typeset -g POWERLEVEL9K_DIR_NOT_WRITABLE_VISUAL_IDENTIFIER_EXPANSION='⭐'

  # NON_EXISTENT directory class — red background, question icon.
  typeset -g POWERLEVEL9K_DIR_NON_EXISTENT_BACKGROUND=1
  typeset -g POWERLEVEL9K_DIR_NON_EXISTENT_FOREGROUND=255

  # ETC directory class.
  typeset -g POWERLEVEL9K_DIR_ETC_BACKGROUND=4
  typeset -g POWERLEVEL9K_DIR_ETC_FOREGROUND=255
  typeset -g POWERLEVEL9K_DIR_ETC_VISUAL_IDENTIFIER_EXPANSION='⚙'

  # HOME directory class.
  typeset -g POWERLEVEL9K_DIR_HOME_BACKGROUND=4
  typeset -g POWERLEVEL9K_DIR_HOME_FOREGROUND=255
  typeset -g POWERLEVEL9K_DIR_HOME_VISUAL_IDENTIFIER_EXPANSION=''

  # HOME_SUBFOLDER directory class.
  typeset -g POWERLEVEL9K_DIR_HOME_SUBFOLDER_BACKGROUND=4
  typeset -g POWERLEVEL9K_DIR_HOME_SUBFOLDER_FOREGROUND=255
  typeset -g POWERLEVEL9K_DIR_HOME_SUBFOLDER_VISUAL_IDENTIFIER_EXPANSION=''

  # DEFAULT directory class — used when no other class matches.
  typeset -g POWERLEVEL9K_DIR_DEFAULT_BACKGROUND=4
  typeset -g POWERLEVEL9K_DIR_DEFAULT_FOREGROUND=255
  typeset -g POWERLEVEL9K_DIR_DEFAULT_VISUAL_IDENTIFIER_EXPANSION=''

  # POWERLEVEL9K_DIR_CLASSES allows you to define custom directory classes that
  # override the built-in ones. This is an array of triplets:
  #   (pattern class icon)
  # Example:
  #   typeset -g POWERLEVEL9K_DIR_CLASSES=(
  #     '~/work(|/*)'  WORK     '💼'
  #     '~/personal/*' PERSONAL '🏠'
  #   )
  typeset -g POWERLEVEL9K_DIR_CLASSES=()

  # Custom prefix icon for the directory segment.
  # typeset -g POWERLEVEL9K_DIR_PREFIX='in '

  # Don't shorten directories that contain any of these files.
  typeset -g POWERLEVEL9K_DIR_PACKAGE_FILE=(package.json composer.json)
  # If set to true, directory names will be hyperlinked to themselves in
  # terminals that support hyperlinks.
  typeset -g POWERLEVEL9K_DIR_HYPERLINK=false
  # If set to true, embed a hyperlink into the directory segment pointing
  # to the current directory. Useful for OSC 7 support.
  typeset -g POWERLEVEL9K_DIR_TRUNCATE_BEFORE_MARKER=false

  #####################################[ vcs: git status ]######################################

  # Version control system colors.
  # Clean state — green background, black foreground.
  typeset -g POWERLEVEL9K_VCS_CLEAN_BACKGROUND=2
  typeset -g POWERLEVEL9K_VCS_CLEAN_FOREGROUND=0
  # Modified state — yellow background, black foreground.
  typeset -g POWERLEVEL9K_VCS_MODIFIED_BACKGROUND=3
  typeset -g POWERLEVEL9K_VCS_MODIFIED_FOREGROUND=0
  # Untracked state — red background, white foreground.
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND=1
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND=255
  # Conflicted state — red background, white foreground.
  typeset -g POWERLEVEL9K_VCS_CONFLICTED_BACKGROUND=1
  typeset -g POWERLEVEL9K_VCS_CONFLICTED_FOREGROUND=255
  # Loading state — gray background (while gitstatus is processing).
  typeset -g POWERLEVEL9K_VCS_LOADING_BACKGROUND=8

  # Branch icon. Nerdfont branch symbol.
  typeset -g POWERLEVEL9K_VCS_BRANCH_ICON='\uF126 '

  # Untracked files icon. It's appended to untracked file count. Example: ?5.
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_ICON='?'

  # Git status formatter function. It uses VCS_STATUS_* parameters set by
  # gitstatus (see https://github.com/romkatv/gitstatus) to produce a formatted
  # string for the git segment.
  #
  # The formatter function is called with one argument: 1 if gitstatus has
  # finished processing, 0 otherwise. When gitstatus hasn't finished, the
  # formatter should use $P9K_CONTENT (the previous value) and return early.
  #
  # Example output: master ⇣2⇡3 *2 ~3 +1 !1 ?5
  #
  # Meaning:
  #   master  — current branch
  #   ⇣2      — 2 commits behind remote
  #   ⇡3      — 3 commits ahead of remote
  #   ⇠       — behind push remote
  #   ⇢       — ahead of push remote
  #   *2      — 2 stashes
  #   ~3      — 3 merge conflicts
  #   +1      — 1 staged change
  #   !1      — 1 unstaged change
  #   ?5      — 5 untracked files
  function my_git_formatter() {
    emulate -L zsh

    if [[ -n $P9K_CONTENT ]]; then
      # If P9K_CONTENT is not empty, use it. It's either the previous value or the
      # temporary value set by the spinner while gitstatus is working.
      typeset -g my_git_format=$P9K_CONTENT
      return
    fi

    # Styling for different states. These use Zsh prompt escape sequences.
    local       meta='%f'     # default foreground
    local      clean='%0F'    # black foreground (on green bg in clean state)
    local   modified='%0F'    # black foreground (on yellow bg in modified state)
    local  untracked='%255F'  # white foreground (on red bg in untracked state)
    local conflicted='%255F'  # white foreground (on red bg in conflicted state)

    local res

    if [[ -n $VCS_STATUS_LOCAL_BRANCH ]]; then
      local branch=${(V)VCS_STATUS_LOCAL_BRANCH}
      # If the branch name is too long, truncate the middle.
      (( $#branch > 32 )) && branch[13,-13]="…"
      res+="${clean}\uF126 ${branch//\%/%%}"
    fi

    if [[ -n $VCS_STATUS_TAG
          # Show tag only if not on a branch.
          && -z $VCS_STATUS_LOCAL_BRANCH
        ]]; then
      local tag=${(V)VCS_STATUS_TAG}
      (( $#tag > 32 )) && tag[13,-13]="…"
      res+="${meta}#${clean}${tag//\%/%%}"
    fi

    # If not on a branch and not on a tag, show the commit hash.
    [[ -z $VCS_STATUS_LOCAL_BRANCH && -z $VCS_STATUS_TAG ]] &&
      res+="${meta}@${clean}${VCS_STATUS_COMMIT[1,8]}"

    # Show remote branch name if it differs from local branch.
    if [[ -n ${VCS_STATUS_REMOTE_BRANCH:#$VCS_STATUS_LOCAL_BRANCH} ]]; then
      res+="${meta}:${clean}${(V)VCS_STATUS_REMOTE_BRANCH//\%/%%}"
    fi

    # Show "wip" if the last commit message starts with "wip" or "WIP".
    if [[ $VCS_STATUS_COMMIT_SUMMARY == (|*[^[:alnum:]])(wip|WIP)(|[^[:alnum:]]*) ]]; then
      res+=" ${modified}wip"
    fi

    # ⇣42 if mass behind the remote.
    (( VCS_STATUS_COMMITS_BEHIND )) && res+=" ${clean}⇣${VCS_STATUS_COMMITS_BEHIND}"
    (( VCS_STATUS_COMMITS_AHEAD && !VCS_STATUS_COMMITS_BEHIND )) && res+=" "
    # ⇡42 if mass ahead of the remote.
    (( VCS_STATUS_COMMITS_AHEAD  )) && res+="${clean}⇡${VCS_STATUS_COMMITS_AHEAD}"
    # ⇠42 if behind the push remote.
    (( VCS_STATUS_PUSH_COMMITS_BEHIND )) && res+=" ${clean}⇠${VCS_STATUS_PUSH_COMMITS_BEHIND}"
    (( VCS_STATUS_PUSH_COMMITS_AHEAD && !VCS_STATUS_PUSH_COMMITS_BEHIND )) && res+=" "
    # ⇢42 if ahead of the push remote.
    (( VCS_STATUS_PUSH_COMMITS_AHEAD  )) && res+="${clean}⇢${VCS_STATUS_PUSH_COMMITS_AHEAD}"
    # *42 if have stashes.
    (( VCS_STATUS_STASHES        )) && res+=" ${clean}*${VCS_STATUS_STASHES}"
    # !42 if have unstaged changes.
    (( VCS_STATUS_NUM_UNSTAGED   )) && res+=" ${modified}!${VCS_STATUS_NUM_UNSTAGED}"
    # ~42 if have merge conflicts.
    (( VCS_STATUS_NUM_CONFLICTED )) && res+=" ${conflicted}~${VCS_STATUS_NUM_CONFLICTED}"
    # +42 if have staged changes.
    (( VCS_STATUS_NUM_STAGED     )) && res+=" ${clean}+${VCS_STATUS_NUM_STAGED}"
    # ?42 if have untracked files. It's really a question mark followed by a number.
    (( VCS_STATUS_NUM_UNTRACKED  )) && res+=" ${untracked}${POWERLEVEL9K_VCS_UNTRACKED_ICON}${VCS_STATUS_NUM_UNTRACKED}"

    typeset -g my_git_format=$res
  }
  functions -M my_git_formatter 2>/dev/null

  # Don't count the number of unstaged, untracked and conflicted files in git repos with more
  # than this many files in the index. Negative value means infinity. Setting this to a
  # non-negative value can make the VCS segment faster in large git repos.
  typeset -g POWERLEVEL9K_VCS_MAX_INDEX_SIZE_DIRTY=-1

  # Don't show git status in the home directory. There's rarely anything useful there.
  typeset -g POWERLEVEL9K_VCS_DISABLED_WORKDIR_PATTERN='~'

  # Disable the default VCS segment formatting and use the custom formatter above.
  typeset -g POWERLEVEL9K_VCS_DISABLE_GITSTATUS_FORMATTING=true
  typeset -g POWERLEVEL9K_VCS_CONTENT_EXPANSION='${$((my_git_formatter(1)))+${my_git_format}}'

  # Icon shown before Git status. Can be changed to any nerdfont icon.
  # typeset -g POWERLEVEL9K_VCS_VISUAL_IDENTIFIER_EXPANSION='⭐'

  # Show status of repositories of these types. You can add svn and/or hg but those
  # will be much slower than git (gitstatus is needed for git, svn and hg use native tools).
  typeset -g POWERLEVEL9K_VCS_BACKENDS=(git)

  # Maximum number of git status items. -1 means no limit.
  typeset -g POWERLEVEL9K_VCS_{STAGED,UNSTAGED,UNTRACKED,CONFLICTED,COMMITS_AHEAD,COMMITS_BEHIND}_MAX_NUM=-1

  # These settings are used for repositories checked out with `git clone --recurse-submodules`.
  typeset -g POWERLEVEL9K_VCS_RECURSE_UNTRACKED_DIRS=false

  # If true, show VCS status for git submodules.
  typeset -g POWERLEVEL9K_VCS_MAX_SYNC_LATENCY_SECONDS=0

  #######################[ status: exit code of the last command ]##############################

  # Enable OK and ERROR status.
  typeset -g POWERLEVEL9K_STATUS_EXTENDED_STATES=true

  # Show status on success. If you set it to false, the status segment won't be shown when
  # the last command succeeds.
  typeset -g POWERLEVEL9K_STATUS_OK=true
  typeset -g POWERLEVEL9K_STATUS_OK_BACKGROUND=0
  typeset -g POWERLEVEL9K_STATUS_OK_FOREGROUND=2
  typeset -g POWERLEVEL9K_STATUS_OK_VISUAL_IDENTIFIER_EXPANSION='✔'

  # Status when the last command succeeded and the preceding command in a pipe also succeeded.
