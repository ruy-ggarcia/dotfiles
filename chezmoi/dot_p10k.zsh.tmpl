  typeset -g POWERLEVEL9K_GCLOUD_COMPLETE_CONTENT_EXPANSION='${P9K_GCLOUD_PROJECT_NAME//\%/%%}'

  ##########[ google_app_cred: google application credentials ]#################################

  typeset -g POWERLEVEL9K_GOOGLE_APP_CRED_SHOW_ON_COMMAND='gcloud|gcs'
  typeset -g POWERLEVEL9K_GOOGLE_APP_CRED_CLASSES=(
    '*'  DEFAULT
  )
  typeset -g POWERLEVEL9K_GOOGLE_APP_CRED_DEFAULT_BACKGROUND=4
  typeset -g POWERLEVEL9K_GOOGLE_APP_CRED_DEFAULT_FOREGROUND=255
  typeset -g POWERLEVEL9K_GOOGLE_APP_CRED_DEFAULT_CONTENT_EXPANSION='${P9K_GOOGLE_APP_CRED_PROJECT_ID//\%/%%}'

  ##################################[ context: user@hostname ]##################################

  # Context color when logged in as root.
  typeset -g POWERLEVEL9K_CONTEXT_ROOT_BACKGROUND=1
  typeset -g POWERLEVEL9K_CONTEXT_ROOT_FOREGROUND=255
  # Context format for root: bold user@hostname.
  typeset -g POWERLEVEL9K_CONTEXT_ROOT_TEMPLATE='%B%n@%m'
  # Context color for regular users (non-root, non-remote).
  typeset -g POWERLEVEL9K_CONTEXT_BACKGROUND=8
  typeset -g POWERLEVEL9K_CONTEXT_FOREGROUND=255
  # Don't show context unless running with privileges or in SSH.
  typeset -g POWERLEVEL9K_CONTEXT_{DEFAULT,SUDO}_{CONTENT,VISUAL_IDENTIFIER}_EXPANSION=
  # Context color when connected via SSH.
  typeset -g POWERLEVEL9K_CONTEXT_REMOTE_BACKGROUND=8
  typeset -g POWERLEVEL9K_CONTEXT_REMOTE_FOREGROUND=255
  typeset -g POWERLEVEL9K_CONTEXT_REMOTE_TEMPLATE='%n@%m'
  # Context color when connected via SSH as root.
  typeset -g POWERLEVEL9K_CONTEXT_REMOTE_SUDO_BACKGROUND=1
  typeset -g POWERLEVEL9K_CONTEXT_REMOTE_SUDO_FOREGROUND=255
  typeset -g POWERLEVEL9K_CONTEXT_REMOTE_SUDO_TEMPLATE='%B%n@%m'
  # Don't show context unless in SSH or running as root.
  typeset -g POWERLEVEL9K_ALWAYS_SHOW_CONTEXT=false

  ###########################[ chezmoi_shell: chezmoi shell indicator ]##########################

  typeset -g POWERLEVEL9K_CHEZMOI_SHELL_BACKGROUND=3
  typeset -g POWERLEVEL9K_CHEZMOI_SHELL_FOREGROUND=0

  #################################[ toolbox: toolbox name ]####################################

  typeset -g POWERLEVEL9K_TOOLBOX_BACKGROUND=3
  typeset -g POWERLEVEL9K_TOOLBOX_FOREGROUND=0
  # Don't show "fedora-toolbox-*" prefix.
  typeset -g POWERLEVEL9K_TOOLBOX_CONTENT_EXPANSION='${P9K_TOOLBOX_NAME:#fedora-toolbox-*}'
  typeset -g POWERLEVEL9K_TOOLBOX_VISUAL_IDENTIFIER_EXPANSION='⬢'

  ##############[ nordvpn: nordvpn connection status ]##########################################

  typeset -g POWERLEVEL9K_NORDVPN_BACKGROUND=4
  typeset -g POWERLEVEL9K_NORDVPN_FOREGROUND=255

  ##########################[ ranger: ranger shell indicator ]##################################

  typeset -g POWERLEVEL9K_RANGER_BACKGROUND=3
  typeset -g POWERLEVEL9K_RANGER_FOREGROUND=0

  ############################[ yazi: yazi shell indicator ]####################################

  typeset -g POWERLEVEL9K_YAZI_BACKGROUND=3
  typeset -g POWERLEVEL9K_YAZI_FOREGROUND=0

  ############################[ nnn: nnn shell indicator ]######################################

  typeset -g POWERLEVEL9K_NNN_BACKGROUND=3
  typeset -g POWERLEVEL9K_NNN_FOREGROUND=0

  ############################[ lf: lf shell indicator ]########################################

  typeset -g POWERLEVEL9K_LF_BACKGROUND=3
  typeset -g POWERLEVEL9K_LF_FOREGROUND=0

  ##########################[ xplr: xplr shell indicator ]######################################

  typeset -g POWERLEVEL9K_XPLR_BACKGROUND=3
  typeset -g POWERLEVEL9K_XPLR_FOREGROUND=0

  ###########################[ vim_shell: vim shell indicator ]#################################

  typeset -g POWERLEVEL9K_VIM_SHELL_BACKGROUND=2
  typeset -g POWERLEVEL9K_VIM_SHELL_FOREGROUND=0

  ##########[ midnight_commander: midnight commander shell indicator ]##########################

  typeset -g POWERLEVEL9K_MIDNIGHT_COMMANDER_BACKGROUND=0
  typeset -g POWERLEVEL9K_MIDNIGHT_COMMANDER_FOREGROUND=3

  ##############################[ nix_shell: nix shell indicator ]##############################

  typeset -g POWERLEVEL9K_NIX_SHELL_BACKGROUND=4
  typeset -g POWERLEVEL9K_NIX_SHELL_FOREGROUND=255

  ##################################[ vi_mode: vi mode ]########################################

  typeset -g POWERLEVEL9K_VI_MODE_BACKGROUND=0
  typeset -g POWERLEVEL9K_VI_INSERT_MODE_STRING=
  typeset -g POWERLEVEL9K_VI_COMMAND_MODE_STRING=NORMAL
  typeset -g POWERLEVEL9K_VI_COMMAND_MODE_FOREGROUND=2
  typeset -g POWERLEVEL9K_VI_VISUAL_MODE_STRING=VISUAL
  typeset -g POWERLEVEL9K_VI_VISUAL_MODE_FOREGROUND=3
  typeset -g POWERLEVEL9K_VI_OVERWRITE_MODE_STRING=OVERTYPE
  typeset -g POWERLEVEL9K_VI_OVERWRITE_MODE_FOREGROUND=1

  ################################[ vpn_ip: VPN indicator ]#####################################

  typeset -g POWERLEVEL9K_VPN_IP_BACKGROUND=0
  typeset -g POWERLEVEL9K_VPN_IP_FOREGROUND=6
  typeset -g POWERLEVEL9K_VPN_IP_SHOW_ALL=false
  # VPN interfaces are commonly called tun*, gpd*, wg*, or tailscale*.
  typeset -g POWERLEVEL9K_VPN_IP_INTERFACE='(gpd|wg|(.*tun)|tailscale)[0-9]*'
  typeset -g POWERLEVEL9K_VPN_IP_CONTENT_EXPANSION=

  ####################################[ load: CPU load ]########################################

  # CPU load average over the last 1 (1), 5 (5) or 15 (15) minutes.
  typeset -g POWERLEVEL9K_LOAD_WHICH=5
  # Load normal/warning/critical colors (green/yellow/red backgrounds).
  typeset -g POWERLEVEL9K_LOAD_NORMAL_BACKGROUND=2
  typeset -g POWERLEVEL9K_LOAD_NORMAL_FOREGROUND=0
  typeset -g POWERLEVEL9K_LOAD_WARNING_BACKGROUND=3
  typeset -g POWERLEVEL9K_LOAD_WARNING_FOREGROUND=0
  typeset -g POWERLEVEL9K_LOAD_CRITICAL_BACKGROUND=1
  typeset -g POWERLEVEL9K_LOAD_CRITICAL_FOREGROUND=255

  ####################################[ disk_usage: disk usage ]################################

  typeset -g POWERLEVEL9K_DISK_USAGE_NORMAL_BACKGROUND=8
  typeset -g POWERLEVEL9K_DISK_USAGE_NORMAL_FOREGROUND=255
  typeset -g POWERLEVEL9K_DISK_USAGE_WARNING_BACKGROUND=3
  typeset -g POWERLEVEL9K_DISK_USAGE_WARNING_FOREGROUND=0
  typeset -g POWERLEVEL9K_DISK_USAGE_CRITICAL_BACKGROUND=1
  typeset -g POWERLEVEL9K_DISK_USAGE_CRITICAL_FOREGROUND=255
  # Thresholds.
  typeset -g POWERLEVEL9K_DISK_USAGE_WARNING_LEVEL=90
  typeset -g POWERLEVEL9K_DISK_USAGE_CRITICAL_LEVEL=95

  ######################################[ ram: free RAM ]#######################################

  typeset -g POWERLEVEL9K_RAM_BACKGROUND=3
  typeset -g POWERLEVEL9K_RAM_FOREGROUND=0

  #####################################[ swap: used swap ]######################################

  typeset -g POWERLEVEL9K_SWAP_BACKGROUND=3
  typeset -g POWERLEVEL9K_SWAP_FOREGROUND=0

  ######################################[ todo: todo items ]####################################

  typeset -g POWERLEVEL9K_TODO_BACKGROUND=8
  typeset -g POWERLEVEL9K_TODO_FOREGROUND=255
  typeset -g POWERLEVEL9K_TODO_HIDE_ZERO_TOTAL=true
  typeset -g POWERLEVEL9K_TODO_HIDE_ZERO_FILTERED=false

  ###########[ timewarrior: timewarrior tracking status ]#######################################

  typeset -g POWERLEVEL9K_TIMEWARRIOR_BACKGROUND=8
  typeset -g POWERLEVEL9K_TIMEWARRIOR_FOREGROUND=255

  ##########[ taskwarrior: taskwarrior task count ]#############################################

  typeset -g POWERLEVEL9K_TASKWARRIOR_BACKGROUND=8
  typeset -g POWERLEVEL9K_TASKWARRIOR_FOREGROUND=255

  ###[ per_directory_history: Oh My Zsh per-directory-history local/global indicator ]##########

  typeset -g POWERLEVEL9K_PER_DIRECTORY_HISTORY_LOCAL_BACKGROUND=0
  typeset -g POWERLEVEL9K_PER_DIRECTORY_HISTORY_LOCAL_FOREGROUND=3
  typeset -g POWERLEVEL9K_PER_DIRECTORY_HISTORY_GLOBAL_BACKGROUND=0
  typeset -g POWERLEVEL9K_PER_DIRECTORY_HISTORY_GLOBAL_FOREGROUND=4

  ################################[ cpu_arch: CPU architecture ]################################

  typeset -g POWERLEVEL9K_CPU_ARCH_BACKGROUND=8
  typeset -g POWERLEVEL9K_CPU_ARCH_FOREGROUND=255
  # Hide the segment when the architecture is x86_64.
  typeset -g POWERLEVEL9K_CPU_ARCH_X86_64_CONTENT_EXPANSION=
  # Hide the segment when the architecture is i386.
  typeset -g POWERLEVEL9K_CPU_ARCH_I386_CONTENT_EXPANSION=

  ##################################[ time: current time ]######################################

  typeset -g POWERLEVEL9K_TIME_BACKGROUND=8
  typeset -g POWERLEVEL9K_TIME_FOREGROUND=255
  # Format for the current time: 09:51:02. See `man 3 strftime`.
  typeset -g POWERLEVEL9K_TIME_FORMAT='%D{%H:%M:%S}'
  # If set to true, time will update when you hit Enter. This way it'll
  # always show the time at which the last command was started.
  typeset -g POWERLEVEL9K_TIME_UPDATE_ON_COMMAND=false
  # Custom icon.
  # typeset -g POWERLEVEL9K_TIME_VISUAL_IDENTIFIER_EXPANSION='⭐'

  #################[ ip: ip address and bandwidth usage for a network interface ]###############

  typeset -g POWERLEVEL9K_IP_BACKGROUND=4
  typeset -g POWERLEVEL9K_IP_FOREGROUND=0
  # The following parameters are available within the expansion:
  #   - P9K_IP_IP     The IP address.
  #   - P9K_IP_INTERFACE The network interface.
  #   - P9K_IP_RX_RATE  Download rate in human-readable form.
  #   - P9K_IP_TX_RATE  Upload rate in human-readable form.
  typeset -g POWERLEVEL9K_IP_CONTENT_EXPANSION='${P9K_IP_RX_RATE:+⇣$P9K_IP_RX_RATE }${P9K_IP_TX_RATE:+⇡$P9K_IP_TX_RATE }$P9K_IP_IP'
  # Show information for the first network interface whose name matches this regular expression.
  typeset -g POWERLEVEL9K_IP_INTERFACE='[ew].*'

  ################################[ public_ip: public IP address ]##############################

  typeset -g POWERLEVEL9K_PUBLIC_IP_BACKGROUND=8
  typeset -g POWERLEVEL9K_PUBLIC_IP_FOREGROUND=255

  ########################[ proxy: system-wide http/https/ftp proxy ]###########################

  typeset -g POWERLEVEL9K_PROXY_BACKGROUND=2
  typeset -g POWERLEVEL9K_PROXY_FOREGROUND=0

  ################################[ battery: internal battery ]#################################

  # Battery colors.
  typeset -g POWERLEVEL9K_BATTERY_LOW_THRESHOLD=20
  typeset -g POWERLEVEL9K_BATTERY_LOW_BACKGROUND=1
  typeset -g POWERLEVEL9K_BATTERY_LOW_FOREGROUND=255
  typeset -g POWERLEVEL9K_BATTERY_CHARGING_BACKGROUND=3
  typeset -g POWERLEVEL9K_BATTERY_CHARGING_FOREGROUND=0
  typeset -g POWERLEVEL9K_BATTERY_DISCONNECTED_BACKGROUND=8
  typeset -g POWERLEVEL9K_BATTERY_DISCONNECTED_FOREGROUND=255
  # Battery icon stages (NerdFont battery icons from empty to full).
  typeset -g POWERLEVEL9K_BATTERY_STAGES=('\uf58d' '\uf579' '\uf57a' '\uf57b' '\uf57c' '\uf57d' '\uf57e' '\uf57f' '\uf580' '\uf581' '\uf578')
  typeset -g POWERLEVEL9K_BATTERY_VERBOSE=false

  #####################################[ wifi: wifi speed ]#####################################

  typeset -g POWERLEVEL9K_WIFI_BACKGROUND=4
  typeset -g POWERLEVEL9K_WIFI_FOREGROUND=255

  ####################################[ TRANSIENT PROMPT ]######################################

  # Transient prompt works similarly to the builtin transient_rprompt option. It trims down
  # prompt when accepting a command line. Supported values:
  #
  #   - off:      Don't change prompt when accepting a command line.
  #   - always:   Trim down prompt when accepting a command line.
  #   - same-dir: Trim down prompt when accepting a command line unless this is the first
  #               command typed after changing current working directory.
  typeset -g POWERLEVEL9K_TRANSIENT_PROMPT=always

  ####################################[ INSTANT PROMPT ]########################################

  # If p10k is slow to load, the instant prompt mode displays a simplified prompt while the
  # full prompt is being loaded in the background. Supported values:
  #
  #   - off:     Disable instant prompt. Choose this if you've tried instant prompt and found
  #              it incompatible with your zsh configuration files.
  #   - quiet:   Enable instant prompt and don't print warnings when detecting console output
  #              during zsh initialization. Choose this if you've read and understood
  #              https://github.com/romkatv/powerlevel10k/blob/master/README.md#instant-prompt.
  #   - verbose: Enable instant prompt and print a warning when detecting console output during
  #              zsh initialization. Choose this if you've never tried instant prompt, haven't
  #              seen the warning, or if you are unsure what this option does.
  typeset -g POWERLEVEL9K_INSTANT_PROMPT=verbose

  ####################################[ HOT RELOAD ]###########################################

  # Hot reload allows you to change POWERLEVEL9K options after Powerlevel10k has been
  # initialized. For example, you can type POWERLEVEL9K_BACKGROUND=red and see the change
  # immediately. This feature is disabled for performance reasons.
  typeset -g POWERLEVEL9K_DISABLE_HOT_RELOAD=true

  ####################################[ CONFIGURATION WIZARD ]##################################

  # If set to true, the configuration wizard will never run. This is set to true here so
  # that the managed configuration is not overwritten by the wizard.
  typeset -g POWERLEVEL9K_DISABLE_CONFIGURATION_WIZARD=true

  # p10k may send unrecognized OSC sequences to the terminal causing temporary artifacts
  # in some terminal emulators. Set to true to enable shell integration features.
  typeset -g POWERLEVEL9K_TERM_SHELL_INTEGRATION=true

  # Finalize the configuration.
  (( ${#p10k_config_opts} )) && setopt ${p10k_config_opts[@]}
  'builtin' 'unset' 'p10k_config_opts'
}
