# ~/.zshrc - Zsh Configuration (Oh My Zsh + Powerlevel10k)
# Managed by Chezmoi. Do not edit directly.
# Source: chezmoi/dot_zshrc.tmpl
# ============================================================================

# ---------------------------------------------------------------------------
# 1. Powerlevel10k Instant Prompt
# ---------------------------------------------------------------------------
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ---------------------------------------------------------------------------
# 2. Environment & PATH
# ---------------------------------------------------------------------------
{{- if eq .chezmoi.os "darwin" }}
# macOS: Homebrew lives in /opt/homebrew on Apple Silicon
export PATH="/opt/homebrew/bin:$PATH"
{{- else if eq .chezmoi.os "linux" }}
# Linux: user-local binaries
export PATH="$HOME/.local/bin:$PATH"
{{- end }}

export EDITOR="${EDITOR:-vim}"
export VISUAL="$EDITOR"
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ---------------------------------------------------------------------------
# 3. Oh My Zsh
# ---------------------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
POWERLEVEL9K_DISABLE_CONFIGURATION_WIZARD=true

plugins=(git)

source $ZSH/oh-my-zsh.sh

# ---------------------------------------------------------------------------
# 4. History
# ---------------------------------------------------------------------------
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt SHARE_HISTORY
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY

# ---------------------------------------------------------------------------
# 5. Dynamic Theme
# ---------------------------------------------------------------------------
# The theme system exports THEME_* color variables, LS_COLORS, and FZF_DEFAULT_OPTS.
# With p10k, we do NOT set PROMPT directly — p10k handles that.
# The terminal emulator's color scheme (Kitty) controls what the p10k color
# indices actually look like.
if [[ -f "$HOME/.config/theme/current.zsh" ]]; then
  source "$HOME/.config/theme/current.zsh"
fi

# ---------------------------------------------------------------------------
# 6. Aliases
# ---------------------------------------------------------------------------

# -- Navigation --
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# -- ls (cross-platform) --
{{- if eq .chezmoi.os "darwin" }}
alias ls='ls -G'
alias ll='ls -lAhG'
alias la='ls -AG'
{{- else if eq .chezmoi.os "linux" }}
alias ls='ls --color=auto'
alias ll='ls -lAh --color=auto'
alias la='ls -A --color=auto'
{{- end }}

# -- Safety --
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias mkdir='mkdir -pv'

# -- Git shortcuts --
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
alias ga='git add'
alias gc='git commit'
alias gp='git push'

# -- Misc --
alias grep='grep --color=auto'
alias df='df -h'
alias du='du -h'
alias path='echo -e ${PATH//:/\\n}'

# ---------------------------------------------------------------------------
# 7. Functions
# ---------------------------------------------------------------------------

# Theme switcher — calls set-theme.sh and re-sources the Zsh theme
set-theme() {
  local script="$HOME/.config/theme/set-theme.sh"
  if [[ -x "$script" ]]; then
    "$script" "$@" && source "$HOME/.config/theme/current.zsh"
  else
    echo "Error: Theme switcher not found at $script"
    echo "Run 'chezmoi apply' to install it."
    return 1
  fi
}

# File swap — swap two files atomically
swap() {
  if [[ $# -ne 2 ]]; then
    echo "Usage: swap <file1> <file2>"
    return 1
  fi
  local tmpfile
  tmpfile=$(mktemp "$(dirname "$1")/XXXXXX")
  mv "$1" "$tmpfile" && mv "$2" "$1" && mv "$tmpfile" "$2"
}

# ---------------------------------------------------------------------------
# 8. Local Overrides
# ---------------------------------------------------------------------------
# Source machine-specific config if it exists (not managed by chezmoi)
if [[ -f "$HOME/.zshrc.local" ]]; then
  source "$HOME/.zshrc.local"
fi

# ---------------------------------------------------------------------------
# 9. Powerlevel10k Configuration
# ---------------------------------------------------------------------------
# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
